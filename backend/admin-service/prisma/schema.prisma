generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Read cache synced from auth-service via RabbitMQ. Not the source of truth —
// suspend/delete actions write back to auth-service, which re-publishes the
// updated state here.
model User {
  id         String    @id
  username   String?
  email      String?
  role       String
  isSuspended Boolean  @default(false) @map("is_suspended")
  blockedAt  DateTime? @map("blocked_at")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  syncedAt   DateTime  @updatedAt @map("synced_at")
  @@map("users")
}

model DoctorVerification {
  id                  String   @id // Doctor.id from auth-service
  userId              String   @map("user_id")
  fullName            String?  @map("full_name")
  specialty           String?
  photoUrl            String?  @map("photo_url")
  verificationStatus  String   @default("pending") @map("verification_status") // pending | verified | rejected
  rejectionReason     String?  @map("rejection_reason")
  reviewedBy          String?  @map("reviewed_by") // admin user id
  reviewedAt          DateTime? @map("reviewed_at")
  createdAt           DateTime @default(now()) @map("created_at")
  syncedAt            DateTime @updatedAt @map("synced_at")

  @@map("doctor_verifications")
}

model FacilityVerification {
  id                  String   @id // ClinicProfile.id or PharmacyProfile.id
  userId              String   @map("user_id")
  facilityType        String   @map("facility_type") // clinic | pharmacy
  name                String?
  photoUrl            String?  @map("photo_url")
  status              String   @default("pending") // pending | verified | suspended
  rejectionReason     String?  @map("rejection_reason")
  reviewedBy          String?  @map("reviewed_by")
  reviewedAt          DateTime? @map("reviewed_at")
  createdAt           DateTime @default(now()) @map("created_at")
  syncedAt            DateTime @updatedAt @map("synced_at")

  @@map("facility_verifications")
}

// Lightweight appointment mirror — just enough for analytics, not a full copy
model AppointmentSummary {
  id                String   @id
  doctorId          String   @map("doctor_id")
  branchId          String   @map("branch_id")
  patientId         String   @map("patient_id")
  status            String
  consultationFee   Int?     @map("consultation_fee")
  date              DateTime @db.Date
  createdAt         DateTime @default(now()) @map("created_at")
  syncedAt          DateTime @updatedAt @map("synced_at")

  @@index([status])
  @@index([date])
  @@map("appointment_summaries")
}

model Ticket {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id") // nullable: admin may open on behalf of someone not fully onboarded, or for internal issues
  subject     String
  status      String   @default("open") // open | pending | closed
  createdBy   String   @map("created_by") // admin user id who opened it, until user-side ticket creation exists
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  messages TicketMessage[]

  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String   @map("ticket_id")
  senderId  String   @map("sender_id") // admin user id (only admin-authored for now)
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  action    String   // e.g. "user.suspend", "doctor.verify"
  targetId  String   @map("target_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([targetId])
  @@map("audit_logs")
}
